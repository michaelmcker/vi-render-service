# Copy to .env and fill in. Never commit .env.

# === Telegram ===
# 1. Talk to @BotFather on Telegram, /newbot, copy token here.
# 2. Both Nikki and the operator each open Telegram, find the bot, send /start.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy each chat.id.
TELEGRAM_BOT_TOKEN=

# Nikki's chat. Briefings, draft pings, urgent alerts, daily summaries go here.
TELEGRAM_PRIMARY_CHAT_ID=

# Comma-separated allowlist of chat IDs that can issue commands and tap buttons.
# Both Nikki and the operator. Anything not in this list is silently ignored.
# System pings (token expired, daemon crashed, cookie refresh needed) broadcast
# to ALL ids in this list.
TELEGRAM_AUTHORIZED_CHAT_IDS=

# === Slack (filled in after running `python -m app.oauth_setup slack`) ===
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_NIKKI_USER_ID=

# === Apollo ===
# Apollo > Settings > Integrations > API > Generate
APOLLO_API_KEY=

# === Salesforce via Zapier ===
# Create a "Catch Hook" Zap that posts to Salesforce.
# Paste the catch-hook URL here. Hermes signs requests with the shared secret.
ZAPIER_SALESFORCE_WEBHOOK=
ZAPIER_SHARED_SECRET=

# === Granola ===
# API auth — confirmed: Granola has an API. Verify exact endpoint paths
# against their docs on first install; if their URL pattern differs from
# the conventional REST shape, override via GRANOLA_LIST_PATH and
# GRANOLA_NOTE_PATH (no code change needed).
GRANOLA_API_KEY=
# Optional overrides if their endpoints differ from the defaults below:
# GRANOLA_API_BASE=https://api.granola.ai/v1
# GRANOLA_LIST_PATH=/notes
# GRANOLA_NOTE_PATH=/notes/{id}

# === LinkedIn ===
# Hermes uses a SECONDARY LinkedIn account for read-only scraping (Playwright)
# so her real account never gets automated against. Setup once:
#   1. Create a separate LinkedIn account with a different email.
#   2. Have it follow ~30-50 industry voices Nikki cares about.
#   3. Run: python -m app.oauth_setup linkedin-cookies
# Cookies save to secrets/linkedin_secondary_cookies.json (no env var needed).
#
# For posting/scheduling, Hermes uses Buffer's API against her REAL account
# via Buffer's official LinkedIn integration (no automation, no ToS risk):
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=

# === Runtime ===
HERMES_HOME=/Users/nikki/hermes
HERMES_LOG_LEVEL=INFO
HERMES_GMAIL_POLL_SECONDS=180
HERMES_DM_POLL_SECONDS=60
HERMES_GRANOLA_POLL_SECONDS=300
HERMES_QUIET_HOURS=21:00-07:00
HERMES_TIMEZONE=America/New_York

# === LLM dispatch ===
# Hermes's main agent runs on Codex (her ChatGPT subscription); claude -p is
# a tool Codex can call. Default is codex. Override per-prompt with
# LLM_BACKEND_<PROMPT_FILE_STEM>=claude (e.g. LLM_BACKEND_DRAFT_REPLY=claude
# to force draft_reply.md through Claude).
HERMES_LLM_DEFAULT=codex
# Override these only if the upstream CLI flags change:
# HERMES_CODEX_BIN=/usr/local/bin/codex
# HERMES_CODEX_ARGS=exec --skip-git-repo-check
# HERMES_CLAUDE_BIN=/usr/local/bin/claude
